# ─────────────────────────────────────────────────────────────────────────────
# LLM Cluster – Environment Configuration
#
# Copy this file to worker/.env or orchestrator/.env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Identity ──────────────────────────────────────────────────────────────────
# Unique name for this node (shown in the orchestrator's worker list)
NODE_NAME=worker-mypc

# ── Worker settings (used by worker/docker-compose.yml) ───────────────────────
# The IP address that other nodes on your network can reach this machine on.
# Run: ip route get 8.8.8.8 | awk '{print $7; exit}'
ADVERTISE_IP=192.168.1.100

# Port for the llama-rpc-server (default: 50052)
RPC_PORT=50052

# Port for the Python sidecar health/status API (default: 8765)
SIDECAR_PORT=8765

# IP of the orchestrator node (optional – for status/logging only)
ORCHESTRATOR_HOST=

# Orchestrator management port (default: 8888)
ORCHESTRATOR_PORT=8888

# How many GPU layers to offload (0 = CPU only, 99 = all layers to GPU)
# Requires GPU Dockerfile and NVIDIA container toolkit
GPU_LAYERS=0

# ── Orchestrator settings (used by orchestrator/docker-compose.yml) ───────────
# Full path to the GGUF model file on the orchestrator's filesystem
MODEL_PATH=/models/Meta-Llama-3-70B-Instruct-Q4_K_M.gguf

# Directory containing the model file (mounted into container)
MODEL_DIR=/models

# llama-server API port (OpenAI-compatible endpoint)
LLAMA_SERVER_PORT=8080

# Orchestrator management API port
MGMT_PORT=8888

# Model context size in tokens
CONTEXT_SIZE=4096

# Number of parallel inference slots (concurrent requests)
PARALLEL=4

# How many seconds without a heartbeat before a worker is considered stale
WORKER_STALE_TIMEOUT=90

# How long to wait for initial worker discovery on orchestrator startup (seconds)
DISCOVERY_TIMEOUT=15

# ── Paths ─────────────────────────────────────────────────────────────────────
# Local directory to mount as /models in the container
# MODEL_DIR=/home/user/models
